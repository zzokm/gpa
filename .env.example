# Copy to .env for docker compose / local production builds:
#   cp .env.example .env

# Optional host port when running `docker compose up` locally (container always listens on 3000).
HOST_PORT=3000

# Dokploy may inject PORT for its UI — do not use it as the app listen port.
# Keep the container on 3000 and set the Dokploy domain service port to 3000.

# Optional base path when serving under a subpath
NEXT_PUBLIC_BASE_PATH=

# GA4 web data stream measurement ID (gtag / GoogleAnalytics).
# Public client value — must be set at *docker build* time (NEXT_PUBLIC_* is inlined).
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Set to true only for static export builds (no API routes)
# STATIC_EXPORT=true
