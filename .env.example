# Copy to .env for docker compose / local production builds:
#   cp .env.example .env

# Host port mapped in docker-compose.yml (container listens on 3000)
PORT=3000

# Optional base path when serving under a subpath
NEXT_PUBLIC_BASE_PATH=

# GA4 web data stream measurement ID (gtag / GoogleAnalytics).
# Public client value — must be set at *docker build* time (NEXT_PUBLIC_* is inlined).
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Set to true only for static export builds (no API routes)
# STATIC_EXPORT=true
